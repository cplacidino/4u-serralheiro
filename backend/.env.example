# ============================================================
# ARQUIVO DE EXEMPLO — Copie como ".env" e preencha os valores
# NUNCA compartilhe o arquivo .env real!
# ============================================================

# Ambiente (development ou production)
NODE_ENV=development

# Porta do servidor
PORT=5000

# MongoDB Atlas — Substitua pela sua connection string
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster0.xxxxx.mongodb.net/4u_serralheiro?retryWrites=true&w=majority

# JWT — Gere uma chave secreta forte (ex: rode no terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=substitua_por_uma_chave_secreta_muito_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# URL do Frontend (para configurar o CORS)
FRONTEND_URL=http://localhost:5173

# E-mail do administrador master do sistema
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=senha_admin_forte_aqui
ADMIN_NAME=Administrador
